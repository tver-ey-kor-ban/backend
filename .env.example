# ── Database ──────────────────────────────────────────────────────────────────
# Local development (Docker Compose)
DATABASE_URL=postgresql://postgres:password123@localhost:5432/mobile_app_db

# Supabase (production) — get from: Supabase → Settings → Database → URI
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── JWT Security ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your_super_secret_jwt_key_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Admin Account ─────────────────────────────────────────────────────────────
# Created automatically on first startup if not exists
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_strong_password

# ── CORS ──────────────────────────────────────────────────────────────────────
# Flutter mobile: use * (mobile apps bypass CORS)
# Flutter web: set your exact domain, e.g. https://myapp.web.app
ALLOWED_ORIGINS=*

# ── Environment ───────────────────────────────────────────────────────────────
# development | production  (controls SQL echo and other settings)
ENVIRONMENT=development

# ── Server ────────────────────────────────────────────────────────────────────
# Number of uvicorn worker processes (use 1 on free-tier hosting)
WORKERS=1

# ── Postgres (used only by docker-compose.prod.yml) ───────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_strong_db_password
POSTGRES_DB=garage_db
